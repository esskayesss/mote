{
  "name": "@mote/backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ../../scripts/ensure-mediasoup-worker.mjs && bun --env-file ../../.env --watch src/index.ts",
    "build": "bun build --target bun ./src/index.ts --outdir dist",
    "check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@elysiajs/cors": "latest",
    "@mote/logging": "workspace:*",
    "@mote/models": "workspace:*",
    "@mote/whisper-client": "workspace:*",
    "elysia": "latest",
    "mediasoup": "latest",
    "unique-names-generator": "^4.7.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "5.7.3"
  }
}
