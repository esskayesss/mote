    "@mote/whisper-client": "workspace:*",
    "elysia": "latest",
    "openai": "^6.32.0",
    "sarvamai": "^1.1.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "5.7.3"
  }
}
