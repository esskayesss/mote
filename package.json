{
  "name": "mote",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --continue=never",
    "check": "turbo run check",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "setup:mediasoup": "node ./scripts/ensure-mediasoup-worker.mjs"
  },
  "devDependencies": {
    "turbo": "latest",
    "typescript": "5.7.3"
  }
}
